# Synapse client build-time configuration.
#
# Vite inlines any variable prefixed with VITE_ into the static bundle at
# build time (`vite build`). Set these in the build environment (CI, Docker
# build args, or a local .env file) before running the production build.

# Base URL of the Synapse_Server that the client connects to over HTTP/WSS.
# Required for production builds. When unset, the client falls back to
# http://localhost:3001 for local development.
# Example: https://api.synapse.example.com
VITE_SERVER_URL=http://localhost:3001
