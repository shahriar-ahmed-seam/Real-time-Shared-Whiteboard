# ─────────────────────────────────────────────────────────────────────────────
# Keep the build context small and reproducible. Anything not needed to install
# dependencies (from the lockfile) and compile/run the server is excluded.
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies — reinstalled deterministically inside the image via `npm ci`.
node_modules

# Build output — regenerated by the build stage (`npm run build`).
dist

# Local environment / secrets — must never be baked into the image.
.env
.env.*
!.env.example

# Tests and test config — not needed in the production image.
test
**/*.test.ts
**/*.spec.ts
vitest.config.ts
vitest.config.*.ts

# Docker / CI artifacts.
Dockerfile
.dockerignore

# Logs and caches.
*.log
npm-debug.log*
.npm
coverage
.nyc_output

# Editor / OS cruft.
.vscode
.idea
.DS_Store
Thumbs.db

# VCS metadata.
.git
.gitignore
