# ─────────────────────────────────────────────────────────────────────────────
# Synapse Server — Example Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values for your environment:
#     cp .env.example .env
#
# The Config_Loader validates every variable at startup. If a REQUIRED variable
# is missing, or any variable fails validation, the server logs one error per
# affected variable and exits with a non-zero status code BEFORE binding the
# port (it never starts misconfigured).
#
# Legend:
#   [REQUIRED] — the server will not start unless this is provided.
#   [OPTIONAL] — may be omitted; the documented default is applied when unset.
# ─────────────────────────────────────────────────────────────────────────────


# ── NODE_ENV ─────────────────────────────────────────────────────────────────
# Purpose:  Selects the runtime environment profile. In "production" the server
#           accepts client connections only over encrypted transport (HTTPS/WSS).
# Status:   [OPTIONAL]
# Allowed:  development | test | production
# Default:  development
NODE_ENV=development


# ── PORT ─────────────────────────────────────────────────────────────────────
# Purpose:  TCP port the HTTP / Socket.IO server binds to.
# Status:   [OPTIONAL]
# Validation: integer in the range 1–65535.
# Default:  3001
PORT=3001


# ── CLIENT_ORIGINS ───────────────────────────────────────────────────────────
# Purpose:  Comma-separated allowlist of client origins permitted by CORS and
#           the Socket.IO handshake. Requests from origins not in this list are
#           rejected.
# Status:   [REQUIRED]
# Validation: each entry must be a well-formed absolute URL (scheme + host).
# Example:  http://localhost:5173,https://app.synapse.example
CLIENT_ORIGINS=http://localhost:5173


# ── DATABASE_URL ─────────────────────────────────────────────────────────────
# Purpose:  Connection URL for the PostgreSQL Persistence_Store that holds
#           durable board and stroke history.
# Status:   [REQUIRED]
# Validation: must be a well-formed absolute URL.
# Example:  postgresql://user:password@localhost:5432/synapse
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/synapse


# ── REDIS_URL ────────────────────────────────────────────────────────────────
# Purpose:  Connection URL for the Redis Coordination_Store used by the
#           Socket.IO adapter (cross-instance broadcast) and distributed presence.
# Status:   [REQUIRED]
# Validation: must be a well-formed absolute URL.
# Example:  redis://localhost:6379
REDIS_URL=redis://localhost:6379


# ── JWT_SECRET ───────────────────────────────────────────────────────────────
# Purpose:  Signing secret for short-lived, room-scoped join tokens. Keep this
#           secret; never commit a real value to source control.
# Status:   [REQUIRED]
# Validation: non-empty string of at least 32 characters.
# Tip:      generate one with `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars


# ── OPEN_MODE ────────────────────────────────────────────────────────────────
# Purpose:  When enabled, bypasses Join_Token verification so rooms can be joined
#           without authentication. Intended for demos / local development ONLY —
#           leave disabled in production.
# Status:   [OPTIONAL]
# Allowed:  true | false
# Default:  false
OPEN_MODE=false


# ── STROKE_CAP ───────────────────────────────────────────────────────────────
# Purpose:  Maximum number of strokes retained in live form per board before
#           compaction occurs (bounds per-board memory and stored history).
# Status:   [OPTIONAL]
# Validation: positive integer.
# Default:  50000
STROKE_CAP=50000


# ── FLUSH_INTERVAL_MS ────────────────────────────────────────────────────────
# Purpose:  Maximum delay (in milliseconds) before buffered strokes are durably
#           persisted to the Persistence_Store by the write-behind buffer.
# Status:   [OPTIONAL]
# Validation: positive integer.
# Default:  1000
FLUSH_INTERVAL_MS=1000


# ── FLUSH_BATCH_SIZE ─────────────────────────────────────────────────────────
# Purpose:  Maximum number of buffered strokes per batched insert; the buffer
#           flushes early once this many strokes accumulate.
# Status:   [OPTIONAL]
# Validation: positive integer.
# Default:  200
FLUSH_BATCH_SIZE=200


# ── MAX_MESSAGE_BYTES ────────────────────────────────────────────────────────
# Purpose:  Maximum accepted size (in bytes) of an inbound socket payload. Used
#           both as the Socket.IO transport `maxHttpBufferSize` hard cap and as
#           an application-level guard that drops oversized events with an
#           invalid-payload error while leaving board state unchanged.
# Status:   [OPTIONAL]
# Validation: positive integer.
# Default:  16384 (16 KiB)
MAX_MESSAGE_BYTES=16384


# ── LOG_LEVEL ────────────────────────────────────────────────────────────────
# Purpose:  Minimum severity level emitted by the structured logger.
# Status:   [OPTIONAL]
# Allowed:  debug | info | warn | error
# Default:  info
LOG_LEVEL=info
